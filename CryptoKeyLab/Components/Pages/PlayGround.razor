@page "/playground"
@using System.Security.Cryptography
@using System.Text

<div class="page-container">
    <main class="content-wrap">
        <h3 class="mb-4">Encrypt & Decrypt Playground</h3>

        <div class="row flex-grow-1">
            <!-- Encrypt Section -->
            <div class="col-md-6 d-flex">
                <div class="card border-primary flex-fill">
                    <div class="card-header bg-primary text-white">
                        <i class="fas fa-lock"></i> Encrypt Data
                    </div>
                    <div class="card-body d-flex flex-column">
                        <div class="form-group flex-grow-1 d-flex flex-column">
                            <label>Enter your data to encrypt:</label>
                            <textarea class="form-control flex-grow-1" @bind="plainText"></textarea>
                        </div>
                        <div class="form-group flex-grow-1 d-flex flex-column mt-2">
                            <label>Enter Public Key:</label>
                            <textarea class="form-control flex-grow-1" @bind="publicKey"></textarea>
                        </div>
                        <button class="btn btn-primary mt-3 align-self-start" >Encrypt Data</button>
                        <div class="form-group flex-grow-1 d-flex flex-column mt-3">
                            <label>Encrypted Result:</label>
                            <div class="input-group flex-grow-1">
                                <textarea class="form-control flex-grow-1" readonly>@encryptedText</textarea>
                                <button class="btn btn-outline-secondary")>Copy</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Decrypt Section -->
            <div class="col-md-6 d-flex">
                <div class="card border-success flex-fill">
                    <div class="card-header bg-success text-white">
                        <i class="fas fa-key"></i> Decrypt Data
                    </div>
                    <div class="card-body d-flex flex-column">
                        <div class="form-group flex-grow-1 d-flex flex-column">
                            <label>Paste Encrypted Data:</label>
                            <textarea class="form-control flex-grow-1" @bind="encryptedInput"></textarea>
                        </div>
                        <div class="form-group flex-grow-1 d-flex flex-column mt-2">
                            <label>Enter Private Key:</label>
                            <textarea class="form-control flex-grow-1" @bind="privateKey"></textarea>
                        </div>
                        <button class="btn btn-success mt-3 align-self-start" >Decrypt Data</button>
                        <div class="form-group flex-grow-1 d-flex flex-column mt-3">
                            <label>Decrypted Message:</label>
                            <div class="input-group flex-grow-1">
                                <textarea class="form-control flex-grow-1" readonly>@decryptedText</textarea>
                                <button class="btn btn-outline-secondary" >Copy</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    @* <footer class="footer bg-dark text-white text-center py-3">
        <p>© 2026 The Prince Cryptography. All rights reserved.</p>
