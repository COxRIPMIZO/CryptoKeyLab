@page "/"
@layout HomeLayout

<MetaTags Title="The Prince Cryptography - Secure. Simple. Accessible."
		  Description="The Prince Cryptography offers powerful and user-friendly cryptographic tools for developers and individuals alike."
		  Keywords="cryptography, RSA key generation, encryption, decryption, secure communication, The Prince Cryptography"
		  ImageUrl="https://yourdomain.com/images/the-prince-cryptography-preview.png"
		  Url="https://yourdomain.com/" />

<div class="hero-section-dark d-flex flex-column justify-content-center align-items-center text-center text-light py-5">
    <div class="glass-card p-5 rounded-4 shadow-lg animate-fade-in">
        <h1 class="display-4 fw-bold mb-3">🔐 The Prince Cryptography</h1>
        <p class="lead">
            We believe security should be <span class="text-info">simple</span>,
            <span class="text-warning">seamless</span>, and
            <span class="text-success">accessible</span> to everyone.
        </p>
        <hr class="my-4 border-light opacity-50" />
        <a href="/KeyGeneration" class="btn btn-lg btn-neon mt-4 px-5 animate-bounce">
            Get Started
        </a>
        <div class="row mt-4">
            <div class="col-md-4 animate-up">
                <i class="bi bi-shield-lock text-info display-5"></i>
                <h5 class="mt-2">Security First</h5>
                <p>Every feature is built with industry‑standard cryptographic practices.</p>
            </div>
            <div class="col-md-4 animate-up">
                <i class="bi bi-lightning-charge text-warning display-5"></i>
                <h5 class="mt-2">Performance</h5>
                <p>Optimized algorithms ensure blazing‑fast key generation.</p>
            </div>
            <div class="col-md-4 animate-up">
                <i class="bi bi-people text-success display-5"></i>
                <h5 class="mt-2">User‑Centric</h5>
                <p>We obsess over clarity, accessibility, and smooth user flows.</p>
            </div>
        </div>
    </div>
</div>


