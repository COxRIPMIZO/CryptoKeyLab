@page "/about"
@layout MainLayout

<MetaTags Title="About The Prince Cryptography - Secure. Simple. Accessible."
		  Description="Learn more about The Prince Cryptography, our mission, and the team behind our powerful cryptographic tools."
		  Keywords="cryptography, about, The Prince Cryptography, secure communication, encryption tools"
		  ImageUrl="https://yourdomain.com/images/the-prince-cryptography-about-preview.png"
		  Url="https://yourdomain.com/about" />

<div class="hero-section-dark d-flex flex-column justify-content-center align-items-center text-center text-light py-5">
    <div class="glass-card p-5 rounded-4 shadow-lg animate-fade-in">
        <h1 class="display-4 fw-bold mb-3">👑 About The Prince Cryptography</h1>
        <p class="lead">
            We believe security should be <span class="text-info">simple</span>,
            <span class="text-warning">seamless</span>, and
            <span class="text-success">accessible</span> to everyone.
        </p>
        <hr class="my-4 border-light opacity-50" />
        <p class="fs-5">
            Founded with a passion for cryptography and user experience,
            <strong>The Prince Cryptography</strong> is designed to empower developers,
            businesses, and individuals with tools that are both powerful and intuitive.
            From generating secure RSA keys to managing encryption workflows,
            our mission is to make cryptography less intimidating and more reliable.
        </p>
        <div class="row mt-4">
            <div class="col-md-4 animate-up">
                <i class="bi bi-shield-lock text-info display-5"></i>
                <h5 class="mt-2">Security First</h5>
                <p>Every feature is built with industry‑standard cryptographic practices.</p>
            </div>
            <div class="col-md-4 animate-up">
                <i class="bi bi-lightning-charge text-warning display-5"></i>
                <h5 class="mt-2">Performance</h5>
                <p>Optimized algorithms ensure blazing‑fast key generation.</p>
            </div>
            <div class="col-md-4 animate-up">
                <i class="bi bi-people text-success display-5"></i>
                <h5 class="mt-2">User‑Centric</h5>
                <p>We obsess over clarity, accessibility, and smooth user flows.</p>
            </div>
        </div>
    </div>
</div>

<!-- Footer -->
<Footer></Footer>